{
  "expo": {
    "name": "الحسن المساعد الشخصي",
    "slug": "waheeb2027",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alhassan-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "يستخدم التطبيق بصمة الوجه للتحقق من هويتك",
        "NSCameraUsageDescription": "يحتاج المساعد إلى الكاميرا لأداء مهامه",
        "NSMicrophoneUsageDescription": "يحتاج المساعد إلى الميكروفون للأوامر الصوتية",
        "NSLocationWhenInUseUsageDescription": "يحتاج المساعد إلى موقعك لأداء مهامه",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يحتاج المساعد إلى موقعك دائماً لأداء مهامه",
        "NSLocationAlwaysUsageDescription": "يحتاج المساعد إلى موقعك في الخلفية",
        "NSContactsUsageDescription": "يحتاج المساعد إلى جهات الاتصال لإدارتها",
        "NSCalendarsUsageDescription": "يحتاج المساعد إلى التقويم لإدارة المواعيد",
        "NSMotionUsageDescription": "يحتاج المساعد إلى بيانات النشاط البدني",
        "NSHealthShareUsageDescription": "يحتاج المساعد إلى بيانات الصحة",
        "NSHealthUpdateUsageDescription": "يحتاج المساعد إلى تحديث بيانات الصحة",
        "NSBluetoothAlwaysUsageDescription": "يحتاج المساعد إلى البلوتوث للاتصال بالأجهزة",
        "NSBluetoothPeripheralUsageDescription": "يحتاج المساعد إلى البلوتوث للاتصال بالأجهزة",
        "NSRemindersUsageDescription": "يحتاج المساعد إلى التذكيرات لإدارتها",
        "NSPhotoLibraryUsageDescription": "يحتاج المساعد إلى مكتبة الصور",
        "NSPhotoLibraryAddUsageDescription": "يحتاج المساعد إلى حفظ الصور",
        "NSSpeechRecognitionUsageDescription": "يحتاج المساعد إلى التعرف على الكلام",
        "UIBackgroundModes": ["fetch", "remote-notification", "processing", "location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.waheeb.walletapp",
      "minSdkVersion": 26,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "allowBackup": false,
      "usesCleartextTraffic": true,
      "blockedPermissions": [],
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "CHANGE_NETWORK_STATE",
        "VIBRATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_CAMERA",
        "FOREGROUND_SERVICE_CONNECTED_DEVICE",
        "FOREGROUND_SERVICE_HEALTH",
        "BIND_NOTIFICATION_LISTENER_SERVICE",
        "SYSTEM_ALERT_WINDOW",
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION",
        "READ_PHONE_STATE",
        "CALL_PHONE",
        "READ_PHONE_NUMBERS",
        "ANSWER_PHONE_CALLS",
        "ADD_VOICEMAIL",
        "USE_SIP",
        "PROCESS_OUTGOING_CALLS",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "GET_ACCOUNTS",
        "READ_CALL_LOG",
        "WRITE_CALL_LOG",
        "BODY_SENSORS",
        "BODY_SENSORS_BACKGROUND",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MANAGE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "SEND_SMS",
        "RECEIVE_SMS",
        "READ_SMS",
        "RECEIVE_WAP_PUSH",
        "RECEIVE_MMS",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "NEARBY_WIFI_DEVICES",
        "UWB_RANGING",
        "PACKAGE_USAGE_STATS",
        "REQUEST_INSTALL_PACKAGES",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "FLASHLIGHT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "alhassan-app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a6ef5",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج المساعد إلى موقعك دائماً لأداء مهامه",
          "locationAlwaysPermission": "يحتاج المساعد إلى موقعك في الخلفية",
          "locationWhenInUsePermission": "يحتاج المساعد إلى موقعك لأداء مهامه",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e2c9d7bd-9560-49a2-80e7-67183d3e2247"
      }
    }
  }
}

