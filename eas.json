{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "android": {
        "buildType": "apk",
        "gradleProperties": {
          "newArchEnabled": "true"
        }
      },
      "distribution": "internal"
    },
    "production": {
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "android": {
        "buildType": "apk",
        "gradleProperties": {
          "newArchEnabled": "true"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
